import math

# Van rental calculation
# Each van holds 15 people and costs $250

tourists = 38
van_seats = 15
van_cost = 250

vans = math.ceil(tourists / van_seats)

total_cost = vans * van_cost

cost_per_person = total_cost / tourists

print(vans)
print(total_cost)
print(format(cost_per_person, ".2f"))

# Output shows vans needed, total cost, and cost per person
# With 38 tourists, we need 3 vans.
# Total cost is 750 dollars.
# Cost per person is 19.74 dollars.