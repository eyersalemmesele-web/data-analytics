# LAB 2 - Rule of 72

current_savings = 1000.00  # current amount in savings
interest_rate = 0.06  # 6% interest rate (decimal form)

# Rule of 72 formula (convert to percent)
years = 72 / (interest_rate * 100)

# Calculate doubled savings
doubled_savings = current_savings * 2

# Output
print("Your current savings is " + format(current_savings, ".2f"))
print("At a " + format(interest_rate, ".0%") + " interest rate, your savings account will be "
      + "worth " + format(doubled_savings, ".2f") + " in " + format(years, ".1f") + " years")

# Notes:
# format(.2f) = 2 decimal places
# format(.1f) = 1 decimal place
# format(.0%) = percentage format
# Rule of 72 uses interest rate in percent, not decimal
#Your current savings is 1000.00
#At a 6% interest rate, your savings account will be worth 2000.00 in 12.0 years
